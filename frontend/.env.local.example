# Drupal backend URL — used server-side only (never exposed to the browser)
DRUPAL_BASE_URL=https://drupal-nextjs-backend.ddev.site

# GraphQL endpoint on the Drupal backend
DRUPAL_GRAPHQL_URL=https://drupal-nextjs-backend.ddev.site/graphql

# Optional: OAuth2 token for authenticated requests (simple_oauth module)
# DRUPAL_CLIENT_ID=your-client-id
# DRUPAL_CLIENT_SECRET=your-client-secret

# ISR / On-demand revalidation secret — must match Drupal webhook config
DRUPAL_REVALIDATE_SECRET=change-this-secret

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

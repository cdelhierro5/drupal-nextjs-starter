{
    "name": "cdelhierro/drupal-nextjs-backend",
    "description": "Drupal 10 headless backend with GraphQL API for Next.js frontend.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Carlos Del Hierro",
            "homepage": "https://www.carlosdelhierro.com"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer/installers": "^2.0",
        "drupal/core-composer-scaffold": "^10",
        "drupal/core-recommended": "^10",
        "drupal/graphql": "^4.8",
        "drupal/metatag": "^2.0",
        "drupal/pathauto": "^1.11",
        "drupal/redirect": "^1.8",
        "drupal/simple_oauth": "^5.2",
        "drupal/token": "^1.12",
        "drush/drush": "^12"
    },
    "require-dev": {
        "drupal/devel": "^5.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true
        },
        "sort-packages": true
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"]
        }
    }
}
